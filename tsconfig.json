{
  "compilerOptions": {
    "target": "ESNext",
    "moduleResolution": "Node",
    "emitDeclarationOnly": true,
    "declaration": true,
    "esModuleInterop": true,
    "outDir": "./dist"
  },
  "include": [
    "src/index.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/*.spec.ts"
  ]
}
