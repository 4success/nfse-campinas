{
  "name": "@4success/nfse-campinas",
  "description": "NFSe Campinas Padrão Nacional DPS v1.01",
  "version": "3.0.1",
  "packageManager": "pnpm@11.10.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "author": {
    "name": "Renan William Alves de Paula",
    "email": "renan@4success.com.br"
  },
  "repository": {
    "url": "git+https://github.com/4success/nfse-campinas.git"
  },
  "scripts": {
    "version": "pnpm run format && git add -A src",
    "prepare": "pnpm run build",
    "prebuild": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "postversion": "git push && git push --tags",
    "test": "jest",
    "build": "tsc --emitDeclarationOnly && node esbuild.mjs",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "tslint -p tsconfig.json"
  },
  "files": [
    "dist/**/*"
  ],
  "directories": {
    "test": "__tests__"
  },
  "keywords": [
    "nfse campinas",
    "nfse",
    "dps",
    "padrao nacional nfse",
    "reforma tributaria"
  ],
  "devDependencies": {
    "@tybys/cross-zip": "^3.1.0",
    "@types/jest": "^29.0.0",
    "@types/luxon": "^3.7.2",
    "@types/node": "^18.19.31",
    "@types/node-forge": "^1.3.11",
    "dotenv": "^16.0.0",
    "esbuild": "^0.23.1",
    "glob": "^8.0.3",
    "jest": "^29.0.0",
    "js-yaml": "^4.1.0",
    "nock": "^13.2.4",
    "prettier": "^2.4.1",
    "ts-jest": "^29.0.0",
    "tslint": "^6.1.3",
    "tslint-config-prettier": "^1.18.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@notaas/danfse-viewer": "1.0.1",
    "axios": "^1.6.1",
    "fast-xml-parser": "^4.2.5",
    "luxon": "^3.7.2",
    "node-forge": "^1.3.1",
    "xml-crypto": "^6.0.0",
    "xmlbuilder": "^15.1.1"
  }
}
